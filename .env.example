# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/restaurant_db?schema=public"

# JWT Configuration
JWT_SECRET="your-secret-key-here-change-in-production"
JWT_EXPIRES_IN="7d"

# Firebase Configuration
# Get these values from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# FIREBASE_PRIVATE_KEY should be the full private key from the JSON file (including -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY-----)
# Replace actual newlines with \n in the private key
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"
FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"

# Application Configuration
NODE_ENV="development"
PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Socket.io Configuration
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
